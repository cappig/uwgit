www.git.cappig.dev git.cappig.dev {
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }

    encode gzip zstd

    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'self'; style-src 'self'; style-src-attr 'unsafe-inline'; img-src 'self' data: https:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    }

    @fonts {
        path *.woff2 *.ttf
    }
    header @fonts Cache-Control "public, max-age=31536000, immutable"

    @static {
        path *.css *.js
    }
    header @static Cache-Control "public, max-age=31536000"

    @icons {
        path /static/img/*
    }
    header @icons Cache-Control "public, max-age=2592000"

    reverse_proxy 127.0.0.1:3000
}
